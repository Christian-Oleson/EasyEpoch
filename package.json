{
  "name": "easyepoch",
  "version": "1.1.0",
  "description": "A lightweight datetime picker in vanilla JavaScript with zero dependencies.",
  "main": "./dist/easyepoch.node.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/easyepoch.node.js",
      "default": "./dist/easyepoch.node.js"
    },
    "./css": "./dist/easyepoch.css"
  },
  "scripts": {
    "start": "rspack serve --hot",
    "prepack": "rspack build --mode production --env production",
    "build": "rspack build --mode production --env production",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint lib/"
  },
  "files": [
    "dist/",
    "easyepoch.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Christian-Oleson/EasyEpoch.git"
  },
  "keywords": [
    "date",
    "picker",
    "datepicker",
    "date-picker",
    "datetime",
    "datetime-picker",
    "vanilla-js",
    "no-dependencies"
  ],
  "author": "Christian Oleson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Christian-Oleson/EasyEpoch/issues"
  },
  "homepage": "https://github.com/Christian-Oleson/EasyEpoch#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^1.7.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.18"
  }
}
